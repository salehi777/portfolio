{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Personal portfolio website built with React and TypeScript",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node server",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "preview": "cross-env NODE_ENV=production node server",
    "ts": "tsc -b",
    "asset-generator": "pwa-asset-generator public/images/logo.png public/pwa-assets -c -f -i index.html -m public/manifest.webmanifest -v /pwa-assets"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.7",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "alova": "^3.5.0",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "i18next": "^25.8.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "keen-slider": "^6.8.6",
    "motion": "^12.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.4",
    "react-router": "^7.13.0",
    "sirv": "^3.0.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/react-lazy-load-image-component": "^1.6.5",
    "@vitejs/plugin-react": "^5.1.3",
    "cross-env": "^10.1.0",
    "globals": "^17.3.0",
    "pwa-asset-generator": "^8.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
